rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function callerEmail() {
      return request.auth != null && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : '';
    }

    function memberAccessForCaller() {
      return get(/databases/$(database)/documents/memberAccess/$(callerEmail())).data;
    }

    function callerIsMemberOf(uid) {
      return isSignedIn()
        && callerEmail() != ''
        && exists(/databases/$(database)/documents/memberAccess/$(callerEmail()))
        && memberAccessForCaller().ownerUid == uid;
    }

    // Owner can read/write their household. Members may only read scoped subtrees.
    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || callerIsMemberOf(userId);
      allow write: if isOwner(userId);
    }

    // /memberAccess maps a member's email -> { ownerUid, memberId, role, ... }.
    // The doc id is the lower-cased email of the family member.
    match /memberAccess/{email} {
      allow read: if isSignedIn() && callerEmail() == email;
      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
